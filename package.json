{
  "name": "@naskot/node-express-compose-middleware",
  "version": "1.0.0",
  "description": "Small Express utility to compose middlewares and a final handler with ctx ({ req, res, next }).",
  "repository": {
    "type": "git",
    "url": "https://github.com/padcmoi/node-express-compose-middleware"
  },
  "homepage": "https://github.com/padcmoi/node-express-compose-middleware",
  "bugs": {
    "url": "https://github.com/padcmoi/node-express-compose-middleware/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write .",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "express",
    "middleware",
    "compose",
    "utility"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "express": ">=4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.5",
    "@types/node": "^24.6.0",
    "eslint": "^10.2.1",
    "express": "^5.1.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}
